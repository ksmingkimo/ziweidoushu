# 数据库 (Vercel Postgres / Neon)
DATABASE_URL=postgresql://user:password@host/dbname

# AI 大模型（选一个即可，DeepSeek 优先）
# DeepSeek API: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude API（备选）
# ANTHROPIC_API_KEY=sk-ant-xxx

# Auth.js 密钥
AUTH_SECRET=your-auth-secret

# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=xxx
ALIYUN_SMS_ACCESS_KEY_SECRET=xxx
ALIYUN_SMS_SIGN_NAME=紫微君
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# 支付宝当面付 https://open.alipay.com → 开发者中心 → 网页/移动应用
ALIPAY_APP_ID=2021xxxxxxxx
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nxxx\n-----END RSA PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nxxx\n-----END PUBLIC KEY-----"
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify

# 站点
NEXT_PUBLIC_SITE_URL=https://your-domain.com
